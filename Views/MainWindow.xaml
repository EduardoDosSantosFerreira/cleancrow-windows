<Window x:Class="CleanCrow.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:CleanCrow.ViewModels"
        xmlns:converters="clr-namespace:CleanCrow.Converters"
        Title="CleanCrow - Otimizador de Sistema"
        Height="750" Width="1000" MinHeight="650" MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        WindowStyle="SingleBorderWindow"
        ResizeMode="CanResizeWithGrip">
    
    <Window.Resources>
        <converters:BooleanInverterConverter x:Key="BooleanInverter"/>
        <converters:StringToBrushConverter x:Key="StringToBrush"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibility"/>
        
        <SolidColorBrush x:Key="LightBgBrush" Color="#2D2D2D"/>
        <SolidColorBrush x:Key="DarkBgBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3A3A3A"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B0B0B0"/>
        
        <SolidColorBrush x:Key="CleanupButtonBrush" Color="#E74C3C"/>
        <SolidColorBrush x:Key="CleanupButtonHoverBrush" Color="#C0392B"/>
        <SolidColorBrush x:Key="UpdateButtonBrush" Color="#3498DB"/>
        <SolidColorBrush x:Key="UpdateButtonHoverBrush" Color="#2980B9"/>
        <SolidColorBrush x:Key="ClearLogsButtonBrush" Color="#7F8C8D"/>
        <SolidColorBrush x:Key="ClearLogsButtonHoverBrush" Color="#616A6B"/>
        
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Width" Value="130"/>
            <Setter Property="Height" Value="130"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="20"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <DataTemplate x:Key="LogItemTemplate">
            <TextBlock FontFamily="Consolas" 
                       FontSize="11"
                       Foreground="{Binding Color}"
                       Text="{Binding FormattedMessage}"
                       TextWrapping="Wrap"/>
        </DataTemplate>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{StaticResource LightBgBrush}"
                CornerRadius="12"
                Padding="25,20"
                Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Image x:Name="LogoImage" 
                       Grid.Column="0"
                       Width="100" 
                       Height="100"
                       Stretch="Uniform"
                       Margin="0,0,20,0"/>
                
                <TextBlock Grid.Column="1" 
                           Text="CLEANCROW"
                           FontSize="42" 
                           FontWeight="Bold"
                           Foreground="#E74C3C"
                           VerticalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect BlurRadius="2" ShadowDepth="1" Opacity="0.3"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <Border Grid.Column="2"
                        Background="{Binding StatusColor, Converter={StaticResource StringToBrush}}"
                        CornerRadius="20"
                        Padding="14,8"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="10" Height="10" 
                                 Fill="White" 
                                 Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding StatusText}"
                                  Foreground="White"
                                  FontSize="13"
                                  FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        
        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Action Buttons -->
            <StackPanel Grid.Row="0" 
                        Orientation="Horizontal" 
                        HorizontalAlignment="Center" 
                        Margin="0,0,0,30">
                
                <Button Style="{StaticResource RoundedButton}"
                        Background="{StaticResource CleanupButtonBrush}"
                        Tag="{StaticResource CleanupButtonHoverBrush}"
                        Command="{Binding StartCleanupCommand}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image x:Name="BroomImage" 
                               Width="60" Height="60"
                               Stretch="Uniform"/>
                        <TextBlock Text="LIMPAR"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource RoundedButton}"
                        Background="{StaticResource UpdateButtonBrush}"
                        Tag="{StaticResource UpdateButtonHoverBrush}"
                        Command="{Binding StartUpdateCommand}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image x:Name="RefreshImage" 
                               Width="60" Height="60"
                               Stretch="Uniform"/>
                        <TextBlock Text="ATUALIZAR"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Button>
                
                <Button Style="{StaticResource RoundedButton}"
                        Background="{StaticResource ClearLogsButtonBrush}"
                        Tag="{StaticResource ClearLogsButtonHoverBrush}"
                        Command="{Binding ClearLogsCommand}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image x:Name="TrashImage" 
                               Width="60" Height="60"
                               Stretch="Uniform"/>
                        <TextBlock Text="LIMPAR LOGS"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   Margin="0,12,0,0"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            
            <!-- Progress Panel -->
            <Border Grid.Row="1"
                    Background="{StaticResource LightBgBrush}"
                    CornerRadius="12"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    Padding="20"
                    Margin="0,5,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <TextBlock Text="{Binding ProgressLabel}"
                                   Grid.Column="0"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <TextBlock Text="{Binding ProgressPercentage}"
                                      Foreground="#3498DB"
                                      FontSize="22"
                                      FontWeight="Bold"
                                      Margin="0,0,15,0"/>
                            <Border Background="{StaticResource DarkBgBrush}"
                                    CornerRadius="12"
                                    Padding="10,5">
                                <TextBlock Text="{Binding OperationsCounter}"
                                          Foreground="{StaticResource TextSecondaryBrush}"
                                          FontSize="13"
                                          FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                    </Grid>
                    
                    <ProgressBar Value="{Binding CurrentProgress}"
                                 Grid.Row="1"
                                 Minimum="0"
                                 Maximum="100"
                                 Height="10"
                                 Margin="0,0,0,12"/>
                    
                    <TextBlock Text="{Binding CurrentOperation}"
                               Grid.Row="2"
                               Foreground="#3498DB"
                               FontSize="12"
                               FontStyle="Italic"
                               Visibility="{Binding IsOperationRunning, Converter={StaticResource BooleanToVisibility}}"/>
                </Grid>
            </Border>
        </Grid>
        
        <!-- Logs Panel -->
        <Border Grid.Row="2"
                Background="{StaticResource LightBgBrush}"
                CornerRadius="12"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0"
                        Background="{StaticResource DarkBgBrush}"
                        CornerRadius="12,12,0,0"
                        Padding="15,12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="LOG DE OPERAÇÕES"
                                  FontSize="13"
                                  FontWeight="Bold"
                                  Foreground="#E74C3C"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding LogsCount, StringFormat=' ({0} registros)'}"
                                  FontSize="11"
                                  Foreground="{StaticResource TextSecondaryBrush}"
                                  VerticalAlignment="Center"
                                  Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>
                
                <ListBox ItemsSource="{Binding Logs}"
                         Grid.Row="1"
                         ItemTemplate="{StaticResource LogItemTemplate}"
                         Background="Transparent"
                         BorderThickness="0"
                         Margin="12,8"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         VirtualizingPanel.ScrollUnit="Pixel">
                    <ListBox.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#3A3A3A"/>
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                    </ListBox.Resources>
                </ListBox>
            </Grid>
        </Border>
        
        <!-- Footer -->
        <Grid Grid.Row="3" Height="5"/>
    </Grid>
</Window>